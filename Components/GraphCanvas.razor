@using GraphTicTacToeCoach.Services
@*
  绘制一个 GraphPuzzle 的 SVG 组件。
  - UsedEdges：已经走过的边（绿色）
  - CurrentVertex：当前所在顶点（高亮）
  - PathVertices：到目前为止走过的顶点序列（用于画顶点序号）
  - OddVertices：要标红的奇度顶点（分析模式用）
  - EdgeOrder：边在欧拉路径中的顺序（分析模式显示数字）
  - ShowDegrees：在顶点旁显示度数
  - OnVertexClick：点击顶点的回调
*@

<svg viewBox="0 0 360 240" class="graph-canvas" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="@Aria">
    <rect x="0" y="0" width="360" height="240" rx="14" fill="#ffffff" stroke="#e9ecef" stroke-width="1.5" />

    @{
        // group parallel edges so multi-edges (e.g. 七桥) curve apart
        var groups = new Dictionary<(int, int), List<int>>();
        for (var e = 0; e < Puzzle.Edges.Count; e++)
        {
            var (a, b) = Puzzle.Edges[e];
            var key = a < b ? (a, b) : (b, a);
            if (!groups.TryGetValue(key, out var lst)) groups[key] = lst = new();
            lst.Add(e);
        }
    }

    @* ========== Edges ========== *@
    @for (var ei = 0; ei < Puzzle.Edges.Count; ei++)
    {
        var e = ei;
        var (a, b) = Puzzle.Edges[e];
        var va = Puzzle.Vertices[a];
        var vb = Puzzle.Vertices[b];
        var key = a < b ? (a, b) : (b, a);
        var group = groups[key];
        var idx = group.IndexOf(e);
        var n = group.Count;
        var offset = (idx - (n - 1) / 2.0) * 22; // px perpendicular offset for parallels

        var dx = vb.X - va.X; var dy = vb.Y - va.Y;
        var len = Math.Max(0.001, Math.Sqrt(dx * dx + dy * dy));
        var nx = -dy / len; var ny = dx / len;
        var mx = (va.X + vb.X) / 2 + nx * offset;
        var my = (va.Y + vb.Y) / 2 + ny * offset;

        var path = $"M {va.X:0.##},{va.Y:0.##} Q {mx:0.##},{my:0.##} {vb.X:0.##},{vb.Y:0.##}";

        var isUsed = UsedEdges is not null && e < UsedEdges.Length && UsedEdges[e];
        var stroke = isUsed ? "#37b24d" : "#adb5bd";
        var width = isUsed ? 6 : 4;

        <path d="@path" fill="none" stroke="@stroke" stroke-width="@width" stroke-linecap="round" />

        @if (EdgeOrder is not null)
        {
            var order = Array.IndexOf(EdgeOrder, e);
            if (order >= 0)
            {
                var lx = (va.X + 2 * mx + vb.X) / 4;
                var ly = (va.Y + 2 * my + vb.Y) / 4;
                @((MarkupString)$"<circle cx='{lx:0.##}' cy='{ly:0.##}' r='11' fill='#fff3bf' stroke='#f59f00' stroke-width='1.5' />")
                @((MarkupString)$"<text x='{lx:0.##}' y='{(ly + 4):0.##}' text-anchor='middle' font-size='12' font-weight='700' fill='#8a6d10'>{order + 1}</text>")
            }
        }
    }

    @* ========== Vertices ========== *@
    @{
        var deg = ComputeDegrees();
    }
    @for (var vi = 0; vi < Puzzle.Vertices.Count; vi++)
    {
        var i = vi;
        var v = Puzzle.Vertices[i];
        var isCurrent = CurrentVertex == i;
        var isOdd = OddVertices is not null && OddVertices.Contains(i);
        var isStart = PathVertices is not null && PathVertices.Count > 0 && PathVertices[0] == i;
        var isEnd = PathVertices is not null && PathVertices.Count > 1 && PathVertices[^1] == i && !isCurrent;

        var fill = isCurrent ? "#ffd86f"
            : isOdd ? "#ffa8a8"
            : isStart ? "#b2f2bb"
            : "#ffffff";
        var stroke = isCurrent ? "#f59f00"
            : isOdd ? "#e03131"
            : "#495057";
        var strokeW = isCurrent ? 4 : 2.5;

        <circle cx="@v.X" cy="@v.Y" r="18"
                fill="@fill" stroke="@stroke" stroke-width="@strokeW"
                style="cursor:pointer;"
                @onclick="() => HandleClick(i)" />

        @((MarkupString)$"<text x='{v.X:0.##}' y='{(v.Y + 5):0.##}' text-anchor='middle' font-size='13' font-weight='700' fill='#2f2620' pointer-events='none'>{v.Label}</text>")

        @if (ShowDegrees)
        {
            var lx = v.X + 22; var ly = v.Y - 18;
            var bg = (deg[i] % 2 == 1) ? "#ffe3e3" : "#d3f9d8";
            var fg = (deg[i] % 2 == 1) ? "#c92a2a" : "#2b8a3e";
            @((MarkupString)$"<rect x='{lx:0.##}' y='{(ly - 10):0.##}' rx='6' ry='6' width='28' height='18' fill='{bg}' stroke='{fg}' stroke-width='1' />")
            @((MarkupString)$"<text x='{(lx + 14):0.##}' y='{(ly + 4):0.##}' text-anchor='middle' font-size='11' font-weight='700' fill='{fg}'>度{deg[i]}</text>")
        }
    }
</svg>

@code {
    [Parameter, EditorRequired] public GraphPuzzle Puzzle { get; set; } = default!;
    [Parameter] public bool[]? UsedEdges { get; set; }
    [Parameter] public int? CurrentVertex { get; set; }
    [Parameter] public List<int>? PathVertices { get; set; }
    [Parameter] public int[]? OddVertices { get; set; }
    [Parameter] public int[]? EdgeOrder { get; set; }
    [Parameter] public bool ShowDegrees { get; set; }
    [Parameter] public string Aria { get; set; } = "图";
    [Parameter] public EventCallback<int> OnVertexClick { get; set; }

    private Task HandleClick(int i) =>
        OnVertexClick.HasDelegate ? OnVertexClick.InvokeAsync(i) : Task.CompletedTask;

    private int[] ComputeDegrees()
    {
        var d = new int[Puzzle.Vertices.Count];
        foreach (var (a, b) in Puzzle.Edges) { d[a]++; d[b]++; }
        return d;
    }
}
