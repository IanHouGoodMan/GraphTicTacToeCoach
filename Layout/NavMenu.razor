@implements IDisposable
@inject NavigationManager Nav

<header class="topbar">
    <div class="topbar-inner">
        <a class="brand" href="/">
            <span class="brand-emoji">🎯</span>
            <span class="brand-text">井字棋图论小课堂</span>
        </a>

        <button class="nav-toggle" @onclick="ToggleMenu" aria-label="菜单">
            <span></span><span></span><span></span>
        </button>

        <nav class="@($"main-nav {(open ? "open" : string.Empty)}")">
            @foreach (var item in Items)
            {
                <NavLink class="nav-pill" href="@item.Href" Match="@(item.Href == "" ? NavLinkMatch.All : NavLinkMatch.Prefix)">
                    <span class="nav-emoji">@item.Emoji</span>
                    <span>@item.Text</span>
                </NavLink>
            }
        </nav>
    </div>
</header>

@code {
    private bool open;

    private record NavItem(string Href, string Emoji, string Text);

    private static readonly NavItem[] Items =
    {
        new("",                  "🏠", "首页"),
        new("graph-theory-intro","🌐", "图论入门"),
        new("play",              "✏️", "自由对战"),
        new("analysis",          "🔍", "图论分析"),
        new("vs-ai",             "🤖", "人机对战"),
        new("proof",             "📜", "和局证明"),
        new("euler",             "🖊️", "一笔画入门"),
        new("euler/practice",    "🎮", "一笔画练习"),
        new("euler/analysis",    "🔬", "一笔画分析"),
    };

    private void ToggleMenu() => open = !open;

    protected override void OnInitialized() => Nav.LocationChanged += HandleNav;

    private void HandleNav(object? s, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (open) { open = false; InvokeAsync(StateHasChanged); }
    }

    public void Dispose() => Nav.LocationChanged -= HandleNav;
}
