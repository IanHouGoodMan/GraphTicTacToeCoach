@page "/vs-ai"
@inject TicTacToeEngine Engine

<PageTitle>人机对战</PageTitle>

<section class="hero">
    <p class="eyebrow">和电脑下棋</p>
    <h1>井字棋 · 人机对战 🤖</h1>
    <p class="lead">
        电脑会用「图」找最好的一步：它先想象自己每一种走法之后的棋盘（图的子节点），
        再从子节点继续想下去……一直想到终局，然后挑最稳的那条边。
    </p>
</section>

<section class="panel">
    <div style="display:grid; gap:1.2rem; grid-template-columns: minmax(280px, 1fr) 1fr;">
        <div class="board-wrap">
            <span class="status-pill @StatusPill">@StatusText</span>

            <div class="board">
                @for (var i = 0; i < 9; i++)
                {
                    var idx = i;
                    var ch = _board[idx];
                    var classes = "cell" + (ch == 'O' ? " o" : string.Empty)
                                  + (_winLine.Contains(idx) ? " win" : string.Empty);
                    <button class="@classes"
                            @onclick="() => Human(idx)"
                            disabled="@(!CanHumanPlay(idx))"
                            aria-label="@TicTacToeEngine.CellName(idx)">
                        @(ch == ' ' ? string.Empty : ch.ToString())
                    </button>
                }
            </div>

            <div class="actions">
                <button class="btn btn-primary" @onclick="NewGame">🔄 新一局</button>
                <button class="btn btn-outline" @onclick="SwapSides">🔁 换边（我现在用 @(_humanSymbol == 'X' ? 'O' : 'X')）</button>
            </div>
        </div>

        <div>
            <h2 style="margin-top:0;">⚙️ 难度</h2>
            <div class="actions" style="justify-content:flex-start;">
                <button class="btn @(Difficulty == AiLevel.Easy ? "btn-success" : "btn-outline")"
                        @onclick="() => SetDifficulty(AiLevel.Easy)">😊 简单</button>
                <button class="btn @(Difficulty == AiLevel.Medium ? "btn-success" : "btn-outline")"
                        @onclick="() => SetDifficulty(AiLevel.Medium)">🙂 中等</button>
                <button class="btn @(Difficulty == AiLevel.Hard ? "btn-success" : "btn-outline")"
                        @onclick="() => SetDifficulty(AiLevel.Hard)">🤓 完美</button>
            </div>

            <h2>🤖 电脑刚才的「图」分析</h2>
            @if (_lastAiOptions.Count == 0)
            {
                <p class="small-note">电脑还没走过棋哦——你先来一步吧。</p>
            }
            else
            {
                <p class="small-note">
                    电脑评估了 @_lastAiOptions.Count 种走法，挑了
                    <strong>@TicTacToeEngine.CellName(_lastAiPick)</strong>。
                </p>
                <div class="graph-tree">
                    @foreach (var m in _lastAiOptions)
                    {
                        var cls = "graph-node " + ResultClass(_aiSymbol, m.Score)
                                  + (m.Index == _lastAiPick ? " optimal" : string.Empty);
                        <div class="@cls">
                            <MiniBoard Board="@m.ResultingBoard" Size="78" />
                            <span class="node-label">@TicTacToeEngine.CellName(m.Index)</span>
                            <span class="node-score">@OutcomeText(_aiSymbol, m.Score)</span>
                            @if (m.Index == _lastAiPick) { <span class="badge">已选 ✅</span> }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>

@code {
    private enum AiLevel { Easy, Medium, Hard }

    private readonly char[] _board = new char[9];
    private char _humanSymbol = TicTacToeEngine.X;
    private char _aiSymbol = TicTacToeEngine.O;
    private char _turn = TicTacToeEngine.X;
    private int[] _winLine = Array.Empty<int>();

    private AiLevel Difficulty { get; set; } = AiLevel.Medium;
    private List<MoveInfo> _lastAiOptions = new();
    private int _lastAiPick = -1;

    private readonly Random _rng = new();

    protected override void OnInitialized() => NewGame();

    private void NewGame()
    {
        for (var i = 0; i < 9; i++) _board[i] = ' ';
        _turn = TicTacToeEngine.X;
        _winLine = Array.Empty<int>();
        _lastAiOptions = new();
        _lastAiPick = -1;
        if (_aiSymbol == 'X') _ = AiMoveAsync();
    }

    private void SwapSides()
    {
        (_humanSymbol, _aiSymbol) = (_aiSymbol, _humanSymbol);
        NewGame();
    }

    private void SetDifficulty(AiLevel d) { Difficulty = d; }

    private bool IsOver => TicTacToeEngine.GetWinner(_board) != ' ';
    private bool CanHumanPlay(int i) => !IsOver && _turn == _humanSymbol && _board[i] == ' ';

    private async Task Human(int i)
    {
        if (!CanHumanPlay(i)) return;
        _board[i] = _humanSymbol;
        _winLine = TicTacToeEngine.WinningLine(_board);
        if (IsOver) return;
        _turn = _aiSymbol;
        await AiMoveAsync();
    }

    private async Task AiMoveAsync()
    {
        StateHasChanged();
        await Task.Delay(280); // small thinking pause

        var options = Engine.AnalyseMoves(_board, _aiSymbol);
        _lastAiOptions = options;
        if (options.Count == 0) return;

        int pick = Difficulty switch
        {
            AiLevel.Easy   => options[_rng.Next(options.Count)].Index,
            AiLevel.Medium => _rng.NextDouble() < 0.5
                              ? options[_rng.Next(options.Count)].Index
                              : PickBest(options),
            _              => PickBest(options),
        };
        _lastAiPick = pick;

        _board[pick] = _aiSymbol;
        _winLine = TicTacToeEngine.WinningLine(_board);
        if (!IsOver) _turn = _humanSymbol;
        StateHasChanged();
    }

    private int PickBest(List<MoveInfo> options)
    {
        var best = options.Where(o => o.IsOptimal).ToList();
        return best.Count == 0 ? options[0].Index : best[_rng.Next(best.Count)].Index;
    }

    private string StatusText => TicTacToeEngine.GetWinner(_board) switch
    {
        var w when w == _humanSymbol => "🎉 你赢啦！",
        var w when w == _aiSymbol    => "🤖 电脑赢了，再来一局！",
        'D' => "🤝 和局！",
        _   => _turn == _humanSymbol ? "👉 轮到你了" : "🤖 电脑思考中…"
    };

    private string StatusPill => TicTacToeEngine.GetWinner(_board) switch
    {
        'D' => "draw",
        _ => _turn == 'X' ? "x" : "o"
    };

    private static string ResultClass(char turn, int score)
    {
        if (score == 0) return "draw";
        if ((turn == 'X' && score == 1) || (turn == 'O' && score == -1)) return "win";
        return "lose";
    }

    private static string OutcomeText(char turn, int score) =>
        ResultClass(turn, score) switch
        {
            "win"  => $"{turn} 必胜 ✅",
            "lose" => $"{TicTacToeEngine.Flip(turn)} 必胜 ❌",
            _      => "和局 🤝"
        };
}
