@page "/euler/practice"
@inject EulerService Euler

<PageTitle>一笔画练习</PageTitle>

<section class="hero">
    <p class="eyebrow">动手挑战</p>
    <h1>一笔画练习 🎮</h1>
    <p class="lead">
        步骤：① 看一眼这张图 → ② 先<strong>猜一猜</strong>能不能一笔画 → ③ 选一个<strong>起点</strong> → ④ 一个一个点击相邻的顶点把所有边走完！
    </p>
</section>

<section class="panel">
    <div class="practice-toolbar">
        <button class="btn btn-primary" @onclick="PickRandom">🎲 抽一道题</button>
        <span class="small-note">题库共 <strong>@Euler.Puzzles.Count</strong> 题</span>
        <select class="puzzle-select" @bind="SelectedId" @bind:after="LoadSelected">
            @foreach (var p in Euler.Puzzles)
            {
                <option value="@p.Id">@p.Name @(p.ExpectedDrawable ? "（能）" : "（不能）")</option>
            }
        </select>
    </div>

    <h2 style="margin-top:1rem;">@Puzzle.Name</h2>
    <p class="small-note" style="white-space: pre-line;">@Puzzle.Story</p>

    @if (!Guessed)
    {
        <div class="guess-bar">
            <strong>先猜：这张图能一笔画吗？</strong>
            <button class="btn btn-success" @onclick="() => Guess(true)">✅ 能</button>
            <button class="btn btn-outline" @onclick="() => Guess(false)">❌ 不能</button>
        </div>
    }
    else
    {
        <div class="guess-result @(GuessCorrect ? "good" : "bad")">
            你猜的：<strong>@(GuessYes ? "能 ✅" : "不能 ❌")</strong>
            ｜ 正确答案：<strong>@(Puzzle.ExpectedDrawable ? "能 ✅" : "不能 ❌")</strong>
            ｜ @(GuessCorrect ? "👏 答对了！" : "差一点点～")
        </div>
    }

    <div class="graph-stage">
        <GraphCanvas Puzzle="@Puzzle"
                     UsedEdges="@Used"
                     CurrentVertex="@Current"
                     PathVertices="@Path"
                     ShowDegrees="@ShowDegrees"
                     OnVertexClick="OnVertexClick"
                     Aria="@Puzzle.Name" />
    </div>

    <div class="status-row">
        <span class="status-pill draw">已走 @Path.Count 个顶点</span>
        <span class="status-pill x">已用 @UsedCount / @Puzzle.Edges.Count 条边</span>
        @if (Status is not null)
        {
            <span class="status-pill o">@Status</span>
        }
    </div>

    <div class="actions">
        <button class="btn btn-outline" @onclick="Undo" disabled="@(Path.Count == 0)">↩️ 悔一步</button>
        <button class="btn btn-outline" @onclick="ResetPath">🧽 清空笔</button>
        <button class="btn @(ShowDegrees ? "btn-success" : "btn-ghost")" @onclick="() => ShowDegrees = !ShowDegrees">
            👁️ @(ShowDegrees ? "隐藏" : "显示")度数
        </button>
        <a class="btn btn-secondary" href="@($"euler/analysis?id={Puzzle.Id}")">🔬 看分析</a>
    </div>

    @if (Completed)
    {
        <div class="big-result good">🎉 太棒啦！你一笔画完成了！共走过 @Puzzle.Edges.Count 条边。</div>
    }
    else if (Stuck)
    {
        <div class="big-result bad">
            😶 卡住了——当前点已经没有能走的边了，但还剩 @(Puzzle.Edges.Count - UsedCount) 条边没画。<br/>
            可以「悔一步」换条路试试，或者点上方「🔬 看分析」让电脑解释。
        </div>
    }
</section>

<section class="panel lesson">
    <h2>💡 小技巧</h2>
    <ol>
        <li>先打开「👁️ 显示度数」，找出所有<strong>红色奇点</strong>。</li>
        <li>有 2 个奇点 → <strong>从一个奇点出发</strong>，走到另一个奇点结束。</li>
        <li>0 个奇点 → 任意起点都行，最后会回到起点。</li>
        <li>奇点 ≥ 4 → 这道题就是「不能」，再聪明也画不出来。</li>
    </ol>
</section>

@code {
    private string SelectedId { get; set; } = "house";
    private GraphPuzzle Puzzle = default!;
    private bool[] Used = Array.Empty<bool>();
    private List<int> Path = new();
    private int? Current;
    private string? Status;
    private bool ShowDegrees;
    private bool Completed;
    private bool Guessed;
    private bool GuessYes;
    private bool GuessCorrect;
    private readonly Random _rng = new();

    private int UsedCount => Used.Count(x => x);

    private bool Stuck =>
        !Completed && Current is int c && !Euler.HasAnyMove(Puzzle, c, Used);

    protected override void OnInitialized() => LoadSelected();

    private void LoadSelected()
    {
        Puzzle = Euler.GetById(SelectedId);
        Used = new bool[Puzzle.Edges.Count];
        Path.Clear();
        Current = null;
        Status = null;
        Completed = false;
        Guessed = false;
    }

    private void PickRandom()
    {
        SelectedId = Euler.Puzzles[_rng.Next(Euler.Puzzles.Count)].Id;
        LoadSelected();
    }

    private void Guess(bool yes)
    {
        GuessYes = yes;
        GuessCorrect = (yes == Puzzle.ExpectedDrawable);
        Guessed = true;
    }

    private void OnVertexClick(int v)
    {
        if (Completed) return;
        if (Path.Count == 0)
        {
            Path.Add(v); Current = v;
            Status = "起点已选好，开始走吧！";
            return;
        }

        var r = Euler.TryStep(Puzzle, Path, Used, v);
        if (!r.Ok) { Status = r.Message; return; }
        if (r.UsedEdgeId is int eid) Used[eid] = true;
        Path.Add(v);
        Current = v;
        Status = r.Message;
        if (r.Completed) Completed = true;
    }

    private void Undo()
    {
        if (Path.Count == 0) return;
        if (Path.Count == 1) { Path.Clear(); Current = null; Status = "起点已取消。"; Completed = false; return; }
        var last = Path[^1];
        var prev = Path[^2];
        Path.RemoveAt(Path.Count - 1);
        // 找到刚才走的边并解锁
        for (var e = 0; e < Puzzle.Edges.Count; e++)
        {
            if (!Used[e]) continue;
            var (a, b) = Puzzle.Edges[e];
            if ((a == prev && b == last) || (b == prev && a == last))
            {
                Used[e] = false; break;
            }
        }
        Current = prev;
        Completed = false;
        Status = "悔了一步～";
    }

    private void ResetPath()
    {
        Used = new bool[Puzzle.Edges.Count];
        Path.Clear();
        Current = null;
        Status = null;
        Completed = false;
    }
}
