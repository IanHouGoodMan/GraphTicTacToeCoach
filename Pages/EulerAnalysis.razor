@page "/euler/analysis"
@inject EulerService Euler
@inject NavigationManager Nav

<PageTitle>一笔画分析</PageTitle>

<section class="hero">
    <p class="eyebrow">让电脑帮你看透这张图</p>
    <h1>一笔画分析 🔬</h1>
    <p class="lead">选一道题，看电脑怎么用「奇点个数」一秒判断、并给出一条可行的笔顺。</p>
</section>

<section class="panel">
    <div class="practice-toolbar">
        <select class="puzzle-select" @bind="SelectedId" @bind:after="OnPuzzleChanged">
            @foreach (var p in Euler.Puzzles)
            {
                <option value="@p.Id">@p.Name</option>
            }
        </select>
        <a class="btn btn-secondary" href="@($"euler/practice?id={SelectedId}")">🎮 去练习这题</a>
    </div>

    <h2 style="margin-top:1rem;">@Puzzle.Name</h2>
    <p class="small-note" style="white-space: pre-line;">@Puzzle.Story</p>

    <div style="display:grid; gap:1rem; grid-template-columns: minmax(280px, 1fr) 1fr; align-items:start;">
        <div class="graph-stage">
            <GraphCanvas Puzzle="@Puzzle"
                         ShowDegrees="true"
                         OddVertices="@Verdict.OddVertices"
                         EdgeOrder="@(ShowTrail ? TrailEdges : null)"
                         Aria="@Puzzle.Name" />
        </div>

        <div class="analysis-side">
            <div class="rule-card @(Verdict.Drawable ? "good" : "bad")">
                @if (Verdict.Drawable) { <span>✅ 这张图<strong>能</strong>一笔画</span> }
                else                    { <span>❌ 这张图<strong>不能</strong>一笔画</span> }
            </div>

            <ul class="fact-list">
                <li>顶点数：<strong>@Puzzle.Vertices.Count</strong></li>
                <li>边数：<strong>@Puzzle.Edges.Count</strong></li>
                <li>是否连通：<strong>@(Verdict.Connected ? "是 ✅" : "否 ❌")</strong></li>
                <li>奇度顶点个数：<strong>@Verdict.OddCount</strong></li>
                <li>判定结论：<span>@Verdict.Kind</span></li>
            </ul>

            @if (Verdict.Drawable)
            {
                <div class="actions" style="justify-content:flex-start;">
                    <button class="btn @(ShowTrail ? "btn-success" : "btn-primary")" @onclick="ToggleTrail">
                        @(ShowTrail ? "👁️ 隐藏笔顺" : "🖍️ 显示一种笔顺")
                    </button>
                    @if (Verdict.StartCandidates.Length > 1)
                    {
                        <select class="puzzle-select" @bind="StartIndex" @bind:after="RecomputeTrail">
                            @foreach (var i in Verdict.StartCandidates)
                            {
                                <option value="@i">从 @Puzzle.Vertices[i].Label 出发</option>
                            }
                        </select>
                    }
                </div>

                @if (ShowTrail && Trail is { Count: > 0 })
                {
                    <p class="small-note" style="margin-top:0.5rem;">
                        笔顺：
                        <strong>@string.Join(" → ", Trail.Select(i => Puzzle.Vertices[i].Label))</strong>
                    </p>
                }
            }
        </div>
    </div>
</section>

<section class="panel lesson">
    <h2>🧠 电脑是怎么算的？</h2>
    <ol>
        <li><strong>统计每个顶点的「度」</strong>：连了几条边就是几度。</li>
        <li><strong>数奇度顶点</strong>：度数是奇数的顶点叫奇点（图上标红）。</li>
        <li><strong>用欧拉定理判断</strong>：奇点数是 0 或 2 → 能；其它 → 不能。</li>
        <li>如果能，就用<strong>Hierholzer 算法</strong>：从合适的起点出发，遇到分叉先走一条圈回来，再插进去，组合成一条完整的笔顺。</li>
    </ol>
</section>

@code {
    [SupplyParameterFromQuery] public string? Id { get; set; }

    private string SelectedId { get; set; } = "house";
    private GraphPuzzle Puzzle = default!;
    private EulerVerdict Verdict = default!;
    private List<int>? Trail;
    private int[]? TrailEdges;
    private bool ShowTrail;
    private int StartIndex;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Id)) SelectedId = Id;
        OnPuzzleChanged();
    }

    private void OnPuzzleChanged()
    {
        Puzzle = Euler.GetById(SelectedId);
        Verdict = Euler.Analyse(Puzzle);
        ShowTrail = false;
        Trail = null;
        TrailEdges = null;
        StartIndex = Verdict.StartCandidates.Length > 0 ? Verdict.StartCandidates[0] : 0;
    }

    private void ToggleTrail()
    {
        ShowTrail = !ShowTrail;
        if (ShowTrail) RecomputeTrail();
    }

    private void RecomputeTrail()
    {
        Trail = Euler.FindTrail(Puzzle, StartIndex);
        TrailEdges = Trail is null ? null : Euler.EdgesOfTrail(Puzzle, Trail).ToArray();
    }
}
